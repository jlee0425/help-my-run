# help-my-run — environment configuration.
# Copy to .env and fill in. .env is git-ignored; never commit real secrets.

# --- Strava OAuth (required) ---
# Create a Strava API app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=123456
STRAVA_CLIENT_SECRET=replace-with-your-strava-client-secret
# Must EXACTLY match the callback registered in the Strava app settings
# and the redirect_uri the backend builds. Points at /api/strava/callback.
STRAVA_REDIRECT_URL=http://localhost:8080/api/strava/callback

# --- App <-> backend auth (required) ---
# Bearer token the Expo app sends on every protected endpoint.
# Generate a long random value, e.g. `openssl rand -hex 32`.
API_TOKEN=replace-with-a-long-random-string

# --- Backend storage / server (optional) ---
# IMPORTANT: `make run-backend` does `cd backend`, so RELATIVE paths resolve under
# backend/ — but the venv, worker, and image dir live at the repo ROOT. Use ABSOLUTE
# paths here (and for PYTHON_BIN/WORKER_SCRIPT/IMAGE_DIR below) to avoid
# "no such file" worker errors and a stray backend/helpmyrun.db.
DB_PATH=/abs/path/to/help-my-run/helpmyrun.db
PORT=8080

# --- Garmin Connect (required for Garmin recovery data) ---
# Used by the one-time `worker.py login`; passed through to the worker by Go.
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=replace-with-your-garmin-password
# Directory where the worker persists refreshed Garmin OAuth tokens.
GARMIN_TOKENSTORE=~/.garminconnect
# M3.2.1: Garmin .FIT fallback start-time match tolerance (seconds).
GARMIN_MATCH_TOLERANCE_S=120

# --- Worker invocation (use ABSOLUTE paths — see the note above) ---
PYTHON_BIN=/abs/path/to/help-my-run/garmin-worker/.venv/bin/python
WORKER_SCRIPT=/abs/path/to/help-my-run/garmin-worker/worker.py

# --- Claude / Anthropic ---
# ⚠️ LEAVE THIS UNSET for the subscription path (the default, $0-per-token).
# `claude` prefers an env API key over your logged-in subscription, so ANY value here
# — even a placeholder — makes `claude -p` use metered API-key billing and fail with a
# 401 ("Invalid API key"). Only uncomment + set a REAL key if you deliberately want
# metered API billing instead of your Claude subscription.
# ANTHROPIC_API_KEY=

# --- Claude Code headless (M1 plans + M2 daily loop + M3.3 chat) ---
# Path to the `claude` CLI. Host must be logged in once: `claude auth login` (NOT --console).
# Headless/remote host with no browser? Run `claude setup-token` once on a machine with
# a browser and expose that token to this host's env.
CLAUDE_BIN=claude
# Model used for vision + planning + chat.
CLAUDE_MODEL=claude-opus-4-8
# Directory where uploaded CrossFit schedule images are saved (read by `claude -p`).
IMAGE_DIR=/abs/path/to/help-my-run/data/crossfit
